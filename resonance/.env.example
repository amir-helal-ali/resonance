# ============================================================================
# Resonance (صدى) — root .env.example
# Copy to `.env` and adjust. All values below are dev-only.
# ============================================================================

# ---- Postgres ----
POSTGRES_PASSWORD=resonance_dev_only_change_me

# ---- Cryptographic anchors ----
# 32-byte HMAC key for blind indexes (base64). Generate with:
#   openssl rand -base64 32
BLIND_INDEX_KEY=c3VwZXItc2VjcmV0LWJsaW5kLWluZGV4LWtleS0zMi1ieXRlcw==

# PoW difficulty: leading zero bits required.
POW_DIFFICULTY_BITS=20

# ---- RTB Engine ----
RTB_AUCTION_TIMEOUT_MS=45
RTB_PLATFORM_SHARE_BPS=3000   # 30% platform, 70% creator

# ---- SMTP (Blind Email Relay) ----
SMTP_HOST=127.0.0.1
SMTP_PORT=25
SMTP_FROM=no-reply@resonance.local

# ---- Backend ----
DATABASE_URL=postgres://resonance:resonance_dev_only_change_me@db:5432/resonance
REDIS_URL=redis://redis:6379/0
BIND_ADDR=0.0.0.0:8080
RUST_LOG=resonance=info,axum=info,tower_http=info
SQLX_OFFLINE=true

# ---- Frontend (browser-facing) ----
VITE_PUBLIC_API_URL=http://localhost:8080
VITE_PUBLIC_WS_URL=ws://localhost:8080/ws
